<% layout("layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-2">Singup on wanderlust</h1>
    <div class="col-6 offset-2" >
        <form action="/signup" method="POST" class="needs-validation" novalidate>

<div class="mb-3">
            <lable for="username" placeholder="title" class="form-label">Username</lable>
            <input name="username"
            id="username"
             type="text" 
             class="form-control"
             required>
            <div class="valid-feedback" >looks good</div>
        </div>
        <div class="mb-3">
            <lable for="email" placeholder="title" class="form-label">E-mail</lable>
            <input name="email"
            id="email"
             type="email" 
             class="form-control"
             required>
            
        </div>
        <div class="mb-3">
            <lable for="password" placeholder="title" class="form-label">Password</lable>
            <input name="password"
            id="password"
             type="password" 
             class="form-control"
             required>
            
        </div>
        <button class="btn btn-success">Singup</button>
        </form>
        </div>
        </div>