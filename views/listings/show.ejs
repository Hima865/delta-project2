<% layout("/layouts/boilerplate") %>
<script>
  const mapToken="<%= process.env.Map_Token%>"
</script>
<div class="row">

  <div class="col-8 offset-2 mt-3">
    <b><%= listing.title %></b>
  </div>

  <div class="card col-6 offset-2">

    <% if(listing.image && listing.image.url){ %>
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_img">
    <% } else { %>
      <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_img">
    <% } %>

    <div class="card-body">

      <p class="card-text">
        Owned by <i><%= listing.owner ? listing.owner.username : "Unknown" %></i>
      </p>

      <p class="card-text"><%= listing.description %></p>

      <p class="card-text">
        ₹ <%= listing.price.toLocaleString("en-IN") %>
      </p>

      <p class="card-text"><%= listing.location %></p>

      <p class="card-text"><%= listing.country %></p>

    </div>
  </div>

  <br>

  <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>

  <div class="btns">

    <a href="/listings/<%= listing._id %>/edit"
       class="btn btn-dark col-1 offset-3 edit-btn">
       Edit
    </a>

    <form method="POST"
          action="/listings/<%= listing._id %>?_method=DELETE">

      <button class="btn btn-dark offset-5">
        Delete
      </button>

    </form>

  </div>

  <% } %>

  <div class="col-8 offset-3">

  <hr>

  <h4>Leave a Review</h4>

  <% if(currUser) { %>

  <form action="/listings/<%= listing._id %>/reviews"
        method="POST"
        novalidate
        class="needs-validation">

  <div class="mb-3 mt-3">

  <label for="rating" class="form-label">Rating</label>

  <fieldset class="starability-slot">

  <input type="radio" class="input-no-rate"
         name="review[rating]"
         value="0"
         checked>

  <input type="radio" name="review[rating]" value="1" id="first-rate1">
  <label for="first-rate1">1 star</label>

  <input type="radio" name="review[rating]" value="2" id="first-rate2">
  <label for="first-rate2">2 stars</label>

  <input type="radio" name="review[rating]" value="3" id="first-rate3">
  <label for="first-rate3">3 stars</label>

  <input type="radio" name="review[rating]" value="4" id="first-rate4">
  <label for="first-rate4">4 stars</label>

  <input type="radio" name="review[rating]" value="5" id="first-rate5">
  <label for="first-rate5">5 stars</label>

  </fieldset>

  </div>

  <div class="mb-3 mt-3">

  <label for="comment" class="form-label">
  comments
  </label>

  <textarea
  name="review[comment]"
  id="comment"
  cols="70"
  rows="5"
  class="form-control"
  required></textarea>

  <div class="invalid-feedback">
  please add some reviews to submit
  </div>

  </div>

  <button class="btn btn-outline-dark">
  Submit
  </button>

  </form>

  <hr/>

  <% } %>

  <%if(listing.reviews.length>0) {%>
  <div class="row">
<p><b>All Reviews</b></p>

  <% for(let review of listing.reviews) { %>

  <div class="card col-5 ms-3 mb-3">

  <div class="card-body">

  <h5 class="card-title">
  @<%= review.author.username %>
  </h5>

  <p class="starability-result card-text"
     data-rating="<%= review.rating %>">
  </p>

  <p class="card-text">
  <%= review.comment %>
  </p>

  </div>

  <% if(currUser && review.author._id.equals(currUser._id)) { %>

  <form method="POST"
  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

  <button class="btn btn-sm btn-dark">
  delete
  </button>

  </form>

  <% } %>

  </div>

  <% } %>

  </div>
<% } %>
  </div>
<div class="col-8 offset-3 mb-3">
  <h3>where you will be</h3>
  <div id="map"></div>
</div>
 
</div>
<script src="/js/map.js"></script>